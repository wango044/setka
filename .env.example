# Telegram API credentials from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Easier mode: create a bot via @BotFather and add it as channel admin.
TELEGRAM_BOT_TOKEN=
TELEGRAM_PUBLISH_MODE=auto

# Optional comma-separated Telegram user IDs allowed to manage posts.
# If empty, the first private user who sends /start to the bot becomes admin.
BOT_ADMIN_USER_IDS=

# Local session file name. The agent stores auth in ./sessions/<name>.session
TELEGRAM_SESSION_NAME=owner

# Optional OpenAI settings for idea/post generation.
# For OpenRouter free models use:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openrouter/free
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Free local LLM mode via Ollama. Install Ollama, then run:
# ollama pull qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# TgPostAI-style post improvement via Gemini API.
GEMINI_API_KEY=
TGPOSTAI_MODEL=gemini-2.5-flash

# Default timezone for scheduling.
TG_GRID_TIMEZONE=Europe/Moscow
TG_GRID_DB_PATH=tg_grid.sqlite3
